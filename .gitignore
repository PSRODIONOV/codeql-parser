# ─────────────────────────────────────────────────────────────
# Личные настройки Claude Code (.claude/settings.json — общий, оставляем)
# ─────────────────────────────────────────────────────────────
.claude/settings.local.json

# Разовые/отладочные артефакты
_test_*/
Error.txt
counter.dat

# ─────────────────────────────────────────────────────────────
# Заимствования: тулчейны/рантаймы/vendored-библиотеки.
# Все лежат в third-party/ (CodeQL, JDK, Maven, Node.js, PHP, Joern,
# node_modules, python-packages, drakonhub_desktop) — докачиваются отдельно.
# ─────────────────────────────────────────────────────────────
third-party/

# ─────────────────────────────────────────────────────────────
# Сгенерированные кодовые базы (полностью регенерируемы)
# ─────────────────────────────────────────────────────────────
databases/

# ─────────────────────────────────────────────────────────────
# Рабочие прогоны анализа и разовые данные (регенерируемы)
# ─────────────────────────────────────────────────────────────
workspace/
data/
_ogdf_build/
native/build/

# ─────────────────────────────────────────────────────────────
# Отчёты: крупные проекты целиком + промежуточные данные везде
# (малые проекты в reports/small-projects/ оставляем — нужны тестам)
# ─────────────────────────────────────────────────────────────
reports/big-projects/
reports/**/work/
reports/**/.cache/
reports/**/.reports_config.json

# ─────────────────────────────────────────────────────────────
# Крупные тест-проекты (клоны публичных репозиториев с github)
# ─────────────────────────────────────────────────────────────
**/test-projects/big-projects/

# ─────────────────────────────────────────────────────────────
# Артефакты сборки внутри тест-проектов
# ─────────────────────────────────────────────────────────────
**/target/
**/build/
**/out/
*.class
*.o
*.obj
*.exe

# ─────────────────────────────────────────────────────────────
# Кэш и временные файлы CodeQL
# ─────────────────────────────────────────────────────────────
*.bqrs
queries/**/.*.ql
queries/**/*.patched

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.pytest_cache/

# ─────────────────────────────────────────────────────────────
# Логи и дампы JVM
# ─────────────────────────────────────────────────────────────
*.log
hs_err_pid*.log
replay_pid*.log
