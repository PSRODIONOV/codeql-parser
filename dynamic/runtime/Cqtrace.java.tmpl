package @PACKAGE@;

import java.io.BufferedWriter;
import java.io.File;
import java.io.FileWriter;
import java.io.IOException;
import java.io.Writer;
import java.lang.management.ManagementFactory;
import java.text.SimpleDateFormat;
import java.util.ArrayDeque;
import java.util.ArrayList;
import java.util.Date;
import java.util.HashMap;
import java.util.List;

/**
 * Рантайм датчиков динамического анализа (Java).
 *
 * Cqtrace.hit(fo, br) — срабатывание датчика: пишет "fo:br".
 *   Вход ФО: hit(fo,0); Выход ФО: hit(fo,-1) (в finally); Ветвь: hit(fo,N).
 *
 * Coverage-строки `fo:br` — анти-спам (№1,2,4,8…). На выходе из вызова ФО также
 * пишутся маршруты: "R fo:b1>b2>..." (ветви) и "C fo:fo>c1>c2>..." (вызовы);
 * подряд идущие повторы схлопываются (циклы/рекурсия), уникальные — 1,2,4,8… раз.
 * Стек кадров — ThreadLocal (корректно при многопоточности).
 * Трассы: <user.home>/<LANG>-<timestamp>-<pid>.log, ротация 100 МБ. LANG —
 * тег трасс (по умолч. "java"), задаётся --trace-tag инструментатора, чтобы
 * трассы нескольких проектов в общем $HOME не путались (см. CQ_LANG/
 * __trace_singlehdr.h у C/C++ — тот же приём).
 */
public final class Cqtrace {
    private static final long LIMIT = 100L * 1024 * 1024;
    private static final String LANG = "@LANG@";
    private static final HashMap<Long, Long> cnt = new HashMap<>();
    private static final HashMap<String, Long> rsig = new HashMap<>();
    private static final Object lock = new Object();
    private static Writer fp = null;
    private static long bytes = 0;

    private Cqtrace() { }

    private static final class Frame {
        final int fo;
        final ArrayList<Integer> br = new ArrayList<>();
        final ArrayList<Integer> cl = new ArrayList<>();
        Frame(int fo) { this.fo = fo; this.cl.add(fo); }
    }

    private static final ThreadLocal<ArrayDeque<Frame>> stack =
            ThreadLocal.withInitial(ArrayDeque::new);

    private static void rotate() throws IOException {
        String ts = new SimpleDateFormat("yyyyMMdd-HHmmss").format(new Date());
        String home = System.getProperty("user.home");
        String pidProp = ManagementFactory.getRuntimeMXBean().getName();
        long pid;
        try { pid = Long.parseLong(pidProp.split("@")[0]); } catch (NumberFormatException e) { pid = 0L; }
        if (fp != null) fp.close();
        fp = new BufferedWriter(new FileWriter(
                home + File.separator + LANG + "-" + ts + "-" + pid + ".log", true));
        bytes = 0;
    }

    /** Запись строки. Предполагает synchronized(lock). */
    private static void writeLine(String s) {
        try {
            if (fp == null || bytes >= LIMIT) rotate();
            fp.write(s);
            fp.flush();
            bytes += s.length();
        } catch (IOException e) {
            /* трассировка не должна ронять программу */
        }
    }

    /** Выгрузка маршрута с анти-спамом по сигнатуре (1,2,4,8…). */
    private static void emit(char tag, int fo, List<Integer> seq) {
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < seq.size(); i++) {
            if (i > 0) sb.append('>');
            sb.append(seq.get(i));
        }
        String body = sb.toString();
        String key = tag + Integer.toString(fo) + ":" + body;
        synchronized (lock) {
            long c = rsig.getOrDefault(key, 0L) + 1;
            rsig.put(key, c);
            if ((c & (c - 1)) != 0) return;
            writeLine(tag + " " + fo + ":" + body + "\n");
        }
    }

    private static void routeEvent(int fo, int br) {
        ArrayDeque<Frame> st = stack.get();
        if (br == 0) {                          // вход в ФО
            Frame parent = st.peek();
            if (parent != null) {               // записать как вызов в кадре-родителе
                List<Integer> cl = parent.cl;
                if (cl.isEmpty() || cl.get(cl.size() - 1) != fo) cl.add(fo);
            }
            st.push(new Frame(fo));
        } else if (br == -1) {                  // выход — выгрузка обоих маршрутов
            Frame fr = st.poll();
            if (fr != null) { emit('R', fr.fo, fr.br); emit('C', fr.fo, fr.cl); }
        } else {                                // ветвь — дописать (без подряд-повторов)
            Frame fr = st.peek();
            if (fr != null) {
                List<Integer> b = fr.br;
                if (b.isEmpty() || b.get(b.size() - 1) != br) b.add(br);
            }
        }
    }

    /**
     * Защита от повторного входа на ТОМ ЖЕ потоке: при инструментации
     * целого JDK под сенсорами оказываются и java.util.HashMap/ArrayDeque/
     * ArrayList/ThreadLocal/Writer, на которых построен этот рантайм —
     * без защиты hit() → cnt.put()/stack.get()/fp.write() (инструментированы)
     * → hit() → … бесконечная рекурсия.
     *
     * Слот на поток (Thread.currentThread().getId(), нативный метод — не
     * вызывает других инструментируемых классов, рекурсия физически
     * невозможна), а НЕ один общий флаг: общий флаг под конкуренцией многих
     * потоков в тугом цикле даёт лайвлок — поток, успевающий взвести/снять
     * флаг быстрее остальных, не оставляет другим окна, где флаг снят, и
     * блокирует их практически навсегда. ThreadLocal/AtomicBoolean/
     * synchronized тут не годятся по той же причине, что и общий флаг —
     * сами были бы вызовами методов других инструментируемых классов.
     * IN_HIT_SLOTS — степень двойки; коллизия слота у двух РАЗНЫХ потоков
     * возможна (редко теряется одно событие), у потока с самим собой — нет.
     */
    private static final int IN_HIT_SLOTS = 1024;
    private static final boolean[] inHit = new boolean[IN_HIT_SLOTS];

    public static void hit(int fo, int br) {
        int slot = (int) (Thread.currentThread().getId() & (IN_HIT_SLOTS - 1));
        if (inHit[slot]) return;
        inHit[slot] = true;
        try {
        routeEvent(fo, br);                      // буфер маршрута — всегда (поток-локально)
        synchronized (lock) {
            long key = (((long) fo) << 32) ^ (br & 0xffffffffL);
            long c = cnt.getOrDefault(key, 0L) + 1;
            cnt.put(key, c);
            if ((c & (c - 1)) != 0) {
                return;                          // не степень двойки → пропуск coverage-строки
            }
            writeLine(fo + ":" + br + "\n");
        }
        } catch (Throwable t) {
            // Трассировка не должна ронять JVM/приложение — особенно на
            // раннем бутстрапе (java.lang.invoke.LambdaForm, ASM-генераторы
            // байткода и т.п. дёргают hit() раньше, чем у ЭТОГО класса успели
            // выполниться static-инициализаторы cnt/stack — NPE на partially-
            // initialized static-полях; см. JLS 12.4.2 про повторный вход в
            // <clinit> того же потока). Гасим ЛЮБОЙ Throwable, не только
            // IOException (как в writeLine) — на бутстрапе сценариев больше,
            // чем можно перечислить заранее.
        } finally {
            inHit[slot] = false;
        }
    }
}
