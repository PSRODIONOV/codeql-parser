/*
 * __trace_rt — реализация рантайма датчиков. Компилируется ОДИН раз и линкуется.
 * Шаблон: инструментатор подставляет __TRACE_LANG и __TRACE_N.
 *
 * Трассы пишутся в домашний каталог: $HOME/<lang>-<timestamp>-<pid>.log
 * Ротация при достижении 100 МБ. pid в имени — чтобы процессы/воркеры не мешали.
 */
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#if defined(_WIN32)
#  include <process.h>
#  include <windows.h>
#  define __getpid _getpid
/* Однократная инициализация CRITICAL_SECTION через спин-флаг:
 *   0 = не инициализирован, 1 = идёт инициализация, 2 = готов. */
static CRITICAL_SECTION __mx;
static volatile LONG     __mx_state = 0;
static void __mx_lock(void) {
    if (InterlockedCompareExchange(&__mx_state, 1, 0) == 0) {
        InitializeCriticalSection(&__mx);
        InterlockedExchange(&__mx_state, 2);
    } else {
        while (__mx_state < 2) { }
    }
    EnterCriticalSection(&__mx);
}
static void __mx_unlock(void) { LeaveCriticalSection(&__mx); }
#else
#  include <unistd.h>
#  include <pthread.h>
#  define __getpid getpid
static pthread_mutex_t __mx = PTHREAD_MUTEX_INITIALIZER;
static void __mx_lock(void)   { pthread_mutex_lock(&__mx); }
static void __mx_unlock(void) { pthread_mutex_unlock(&__mx); }
#endif

#define __TRACE_LANG  "@LANG@"
#define __TRACE_N     @COUNT@
#define __TRACE_LIMIT (100u * 1024u * 1024u)   /* 100 МБ */

static unsigned __cnt[__TRACE_N + 1];          /* счётчик срабатываний на датчик */
static FILE   *__fp = NULL;
static size_t  __bytes = 0;

static void __rotate(void) {
    char path[1024], ts[32];
    time_t t = time(NULL);
    struct tm tmv;
#if defined(_WIN32)
    struct tm *tp = localtime(&t); if (tp) tmv = *tp;
#else
    localtime_r(&t, &tmv);
#endif
    strftime(ts, sizeof ts, "%Y%m%d-%H%M%S", &tmv);
    const char *home = getenv("HOME");
    if (!home) home = getenv("USERPROFILE");
    if (!home) home = ".";
    snprintf(path, sizeof path, "%s/%s-%s-%d.log", home, __TRACE_LANG, ts, (int)__getpid());
    if (__fp) fclose(__fp);
    __fp = fopen(path, "a");
    __bytes = 0;
}

#ifdef __cplusplus
extern "C"
#endif
void __trace_hit(unsigned sid, int fo, int br) {
    /* анти-спам: писать только на степенях двойки числа срабатываний датчика */
    if (sid <= (unsigned)__TRACE_N) {
        unsigned c = ++__cnt[sid];
        if (c & (c - 1)) return;               /* не степень двойки → пропустить */
    }
    __mx_lock();
    if (!__fp || __bytes >= __TRACE_LIMIT) __rotate();
    if (__fp) {
        int n = fprintf(__fp, "%d:%d\n", fo, br);
        if (n > 0) __bytes += (size_t)n;
        fflush(__fp);                          /* краш-устойчивость (демо-объёмы) */
    }
    __mx_unlock();
}
